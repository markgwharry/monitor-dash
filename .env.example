# Pi Dashboard Environment Variables
# Copy to .env and fill in your values

# OpenWeatherMap
DASHBOARD_WEATHER_API_KEY=

# Calendar ICS URLs (JSON array)
DASHBOARD_CALENDAR_ICS_URLS=[]

# Home Assistant
DASHBOARD_HOMEASSISTANT_URL=http://192.168.1.125:8123
DASHBOARD_HOMEASSISTANT_TOKEN=
DASHBOARD_CAMERA_ENTITY_ID=camera.driveway_live_view_2

# Air Quality Sensor
DASHBOARD_AIR_SENSOR_URL=http://192.168.1.65

# CUPS
DASHBOARD_CUPS_URL=http://192.168.1.125:631

# Portainer
DASHBOARD_PORTAINER_URL=http://192.168.1.125:9000
DASHBOARD_PORTAINER_API_KEY=
DASHBOARD_PORTAINER_ENDPOINT_ID=3

# Aine letters game path (relative to dashboard repo)
DASHBOARD_LETTERS_GAME_PATH=../aine-letters/repo
